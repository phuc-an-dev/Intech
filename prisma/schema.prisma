generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum CourseLevel {
  foundation
  tools
  application
  advanced
  strategic
}

enum TourStatus {
  DRAFT
  PUBLISHED
}

model Category {
  id        String   @id @default(cuid())
  key       String   @unique
  name_vi   String
  name_en   String
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Author {
  id        String   @id @default(cuid())
  name      String
  role_vi   String
  role_en   String
  image     String
  imageAlt  String
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Topic {
  id             String   @id @default(cuid())
  slug           String   @unique
  name_vi        String
  name_en        String
  description_vi String   @db.Text
  description_en String   @db.Text
  courses        Course[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Course {
  id                 String       @id @default(cuid())
  slug               String       @unique
  status             CourseStatus @default(DRAFT)
  level              CourseLevel  @default(foundation)
  topicId            String
  topic              Topic        @relation(fields: [topicId], references: [id])
  durationHours      Int          @default(0)
  durationSessions   Int          @default(0)
  title_vi           String       @db.Text
  title_en           String       @db.Text
  description_vi     String       @db.Text
  description_en     String       @db.Text
  learningOutcome_vi String       @db.Text
  learningOutcome_en String       @db.Text
  targetAudience_vi  Json
  targetAudience_en  Json
  modules_vi         Json
  modules_en         Json
  finalProject_vi    String       @db.Text
  finalProject_en    String       @db.Text
  deliveryFormat_vi  String
  deliveryFormat_en  String
  tags               Json
  prerequisite       String?      @db.Text
  priceOriginal      Int          @default(0)
  priceSale          Int?
  imageUrl           String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([status])
  @@index([topicId])
  @@index([level])
}

model Tour {
  id             String     @id @default(cuid())
  slug           String     @unique
  status         TourStatus @default(PUBLISHED)
  order          Int        @default(0)
  coverImage     String     @default("")
  duration_vi    String
  duration_en    String
  name_vi        String
  name_en        String
  subtitle_vi    String     @db.Text
  subtitle_en    String     @db.Text
  destination_vi String
  destination_en String
  price_vi       String
  price_en       String
  groupSize_vi   String
  groupSize_en   String
  certificate_vi String     @db.Text
  certificate_en String     @db.Text
  whyJoin_vi     String     @db.Text
  whyJoin_en     String     @db.Text
  customization_vi String   @db.Text
  customization_en String   @db.Text
  highlights_vi  Json
  highlights_en  Json
  audience_vi    Json
  audience_en    Json
  itinerary_vi   Json
  itinerary_en   Json
  includes_vi    Json
  includes_en    Json
  excludes_vi    Json
  excludes_en    Json
  gallery_vi     Json
  gallery_en     Json
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status])
}

model Post {
  id                String     @id @default(cuid())
  slug              String     @unique
  status            PostStatus @default(DRAFT)
  pinned            Boolean    @default(false)
  lang              String
  title_vi          String     @db.Text
  title_en          String     @db.Text
  excerpt_vi        String     @db.Text
  excerpt_en        String     @db.Text
  body_vi           String     @db.LongText
  body_en           String     @db.LongText
  tags              Json
  gradient          String
  coverImage        String?
  readTime          Int        @default(5)
  date              DateTime
  relatedCourseSlug String?
  categoryId        String
  authorId          String
  category          Category   @relation(fields: [categoryId], references: [id])
  author            Author     @relation(fields: [authorId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([status])
  @@index([pinned])
  @@index([categoryId])
  @@index([authorId])
}
